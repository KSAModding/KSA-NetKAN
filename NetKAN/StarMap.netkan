identifier: StarMap
name: StarMap
abstract: Mod loader that runs code mods for Kitten Space Agency.
author: klaaswhite
license: MIT
$kref: '#/ckan/github/StarMapLoader/StarMap/asset_match/StarMapStandalone'
release_status: stable
resources:
  homepage: https://github.com/StarMapLoader/StarMap
  repository: https://github.com/StarMapLoader/StarMap
tags:
  - library
ksp_version: 2026.7.3.4826
install:
  - find_regexp: '.*'
    install_to: mods/StarMap
    find_matches_files: true
